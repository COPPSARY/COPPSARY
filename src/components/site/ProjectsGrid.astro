---
const { projects } = Astro.props;
---

<section id="projects" class="work-section">
  <div class="work-section__heading">
    <div class="section-label">(03) Work</div>
    <div class="section-heading__content">
      <p class="section-statement">Our past Works.</p>
    </div>
  </div>

  <div class="work-reel">
    {projects.map((project, index) => (
      <a
        href={`/projects/${project.slug}`}
        class={`work-row work-row--${index % 2 === 0 ? 'left' : 'right'}`}
        aria-label={`View ${project.title} case study`}
      >
        <div class="work-row__media">
          {project.video ? (
            <video
              src={project.video}
              autoplay
              muted={true}
              loop
              playsinline
              preload="none"
            />
          ) : (
            <img
              src={project.image}
              alt={`${project.title} screenshot`}
              loading="lazy"
              decoding="async"
            />
          )}
          {project.live && <span class="work-row__live">Live</span>}
        </div>

        <div class="work-row__info">
          <div class="work-row__index">{String(index + 1).padStart(2, '0')}</div>
          <h3 class="work-row__title">{project.title}</h3>
          <p class="work-row__desc">{project.description}</p>
          {project.tags && (
            <ul class="work-row__tags" role="list">
              {project.tags.map((tag) => <li>{tag}</li>)}
            </ul>
          )}
          <span class="work-row__cta">View case study →</span>
        </div>
      </a>
    ))}
  </div>
</section>
