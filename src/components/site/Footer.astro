---
import { siteMeta } from '../../data/aurea.js';

const year = new Date().getFullYear();
---

<footer class="footer-shell">
  <div class="footer-bar">
    <span class="footer-wordmark">© AUREA / {year}</span>
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="/#projects">Work</a>
      <a href="/about">Studio</a>
      <a href="/#contact">Contact</a>
    </nav>
    <div class="footer-socials" aria-label="Social links">
      <a href={siteMeta.facebook} target="_blank" rel="noreferrer" aria-label="AUREA Facebook">
        <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
          <path d="M13.5 21v-7h2.3l.4-3h-2.7V9.2c0-.9.3-1.5 1.6-1.5H16V5.1c-.2 0-.9-.1-1.8-.1-2.9 0-4.8 1.8-4.8 5V11H7v3h2.4v7h4.1Z"></path>
        </svg>
      </a>
      <a href={siteMeta.tiktok} target="_blank" rel="noreferrer" aria-label="AUREA TikTok">
        <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
          <path d="M16.6 3c.3 1.8 1.4 3.2 3.1 4 .4.2.8.3 1.3.4v3.1a8.4 8.4 0 0 1-4.4-1.3v5.9c0 3.5-2.8 6.2-6.3 6.2A6.2 6.2 0 0 1 4 15.1c0-3.4 2.8-6.2 6.3-6.2h.7v3.2h-.7a3 3 0 0 0-3 3c0 1.7 1.3 3 3 3s3-1.3 3-3V3h3.3Z"></path>
        </svg>
      </a>
    </div>
  </div>
</footer>
