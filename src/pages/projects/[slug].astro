---
import Footer from '../../components/site/Footer.astro';
import Header from '../../components/site/Header.astro';
import SmoothScroll from '../../components/site/SmoothScroll.jsx';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { contactDetails, projects } from '../../data/aurea.js';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const currentIndex = projects.findIndex(p => p.slug === project.slug);
const nextProject = projects[(currentIndex + 1) % projects.length];
---

<BaseLayout
  title={`${project.title} — AUREA`}
  description={project.description}
  canonical={`https://coppsary.com/projects/${project.slug}`}
>
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <div class="site-shell">
    <SmoothScroll client:load />
    <Header pathname={Astro.url.pathname} />

    <main id="main-content">

      <!-- Hero -->
      <section class="project-detail__hero">
        <div class="project-detail__hero-inner">
          <a href="/projects" class="project-detail__back">← All projects</a>
          <div class="project-detail__meta">
            <div class="project-detail__meta-item">
              <span class="project-detail__meta-label">Project</span>
              <span class="project-detail__meta-value">{project.title}</span>
            </div>
            {project.live && (
              <div class="project-detail__meta-item">
                <span class="project-detail__meta-label">Status</span>
                <span class="project-detail__meta-value" style="color: var(--brand);">Live</span>
              </div>
            )}
            <div class="project-detail__meta-item">
              <span class="project-detail__meta-label">Tags</span>
              <span class="project-detail__meta-value">{project.tags?.join(', ')}</span>
            </div>
          </div>
          <h1 class="display-title">{project.title}</h1>
          <p>{project.description}</p>
        </div>
      </section>

      <!-- Media -->
      <div class={`project-detail__media${project.video ? ' project-detail__media--video' : ''}`}>
        {project.video ? (
          <video
            src={project.video}
            autoplay
            muted={true}
            loop
            playsinline
            preload="auto"
          />
        ) : (
          <img
            src={project.image}
            alt={`${project.title} screenshot`}
            loading="eager"
            decoding="async"
          />
        )}
      </div>

      <!-- Body -->
      <div class="project-detail__body">
        <div>
          <p class="project-detail__long-desc">{project.longDescription}</p>
          <a
            href={project.url}
            target="_blank"
            rel="noreferrer"
            class="project-detail__visit"
          >
            Visit live site <span aria-hidden="true">↗</span>
          </a>
        </div>

        <div class="project-detail__highlights">
          <p class="project-detail__highlights-title">Highlights</p>
          {project.highlights?.map(h => (
            <div class="project-detail__highlight">{h}</div>
          ))}
        </div>
      </div>

      <!-- Screenshot fallback if video -->
      {project.video && (
        <div style="width: var(--container); margin: 0 auto; padding-bottom: var(--section-space);">
          <img
            src={project.image}
            alt={`${project.title} screenshot`}
            loading="lazy"
            decoding="async"
            style="width: 100%; display: block; border: 1px solid var(--line);"
          />
        </div>
      )}

      <!-- Next project -->
      <section class="project-detail__next">
        <a href={`/projects/${nextProject.slug}`} class="project-detail__next-link">
          <span class="project-detail__next-label">Next project</span>
          <span class="project-detail__next-title">{nextProject.title}</span>
          <span class="project-detail__next-arrow" aria-hidden="true">→</span>
        </a>
      </section>

      <!-- Contact -->
      <section class="contact-section">
        <div class="contact-section__dot" aria-hidden="true"></div>
        <div class="contact-section__content">
          <div class="section-label section-label--dark">Start a project</div>
          <h2>{contactDetails.headline}</h2>
          <div class="contact-section__links" aria-label="Direct contact links">
            <a href={contactDetails.email} class="contact-section__link">
              <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 6h16v12H4z"></path>
                <path d="m4 7 8 6 8-6"></path>
              </svg>
              {contactDetails.emailLabel}
            </a>
            <a href={contactDetails.telegram} target="_blank" rel="noreferrer" class="contact-section__link">
              <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
                <path d="M21.4 4.6c.3-.9-.6-1.7-1.5-1.4L3.8 9.4c-1 .4-1 1.8.1 2.1l4.1 1.3 1.6 5c.3 1 1.6 1.1 2.1.2l2.3-3.2 4.4 3.3c.8.6 1.9.2 2.1-.8l.9-12.7ZM9.1 12.1l8.4-5.2-6.9 6.7-.3 2.7-1.2-4.2Z"></path>
              </svg>
              {contactDetails.telegramLabel}
            </a>
            <a href={contactDetails.phone} class="contact-section__link">
              <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7l.5 3a2 2 0 0 1-.6 1.8l-1.3 1.3a16 16 0 0 0 6.4 6.4l1.3-1.3a2 2 0 0 1 1.8-.6l3 .5A2 2 0 0 1 22 16.9z"></path>
              </svg>
              {contactDetails.phoneLabel}
            </a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
.project-detail__back {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.74rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--text-muted);
  text-decoration: none;
  transition: color 180ms ease;
}
.project-detail__back:hover {
  color: var(--text);
}

.project-detail__next {
  border-top: 1px solid var(--line);
}

.project-detail__next-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  width: var(--container);
  margin: 0 auto;
  padding: clamp(2rem, 5vw, 4rem) 0;
  text-decoration: none;
  color: inherit;
  transition: color 200ms ease;
}

.project-detail__next-link:hover {
  color: var(--brand);
}

.project-detail__next-label {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--text-muted);
  flex-shrink: 0;
}

.project-detail__next-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 4.5rem);
  line-height: 0.92;
  letter-spacing: 0.01em;
  flex: 1;
  text-align: center;
}

.project-detail__next-arrow {
  font-size: clamp(1.5rem, 3vw, 2.5rem);
  flex-shrink: 0;
  transition: transform 200ms ease;
}

.project-detail__next-link:hover .project-detail__next-arrow {
  transform: translateX(6px);
}
</style>
